BOT_TOKEN=ваш_токен_здесь

# PostgreSQL: полная схема — sql/schema_full.sql (сброс), автомиграция — sql/schema_bootstrap.sql
DATABASE_URL=postgresql://user:password@localhost:5432/tg_bot
# true: при старте применяются DDL из init (crypto_pay_invoices + subscriptions / subscription_types)
DB_AUTO_MIGRATE=false
# Если ошибка «нет доступа к схеме public» (42501): своя схема провайдера, например имя пользователя БД:
# PG_SEARCH_PATH=mydbuser
# Или выдайте права: GRANT USAGE ON SCHEMA public TO ваш_пользователь;

# --- Remnawave (панель): если задан REMNAWAVE_BASE_URL — бот создаёт пользователей через API ---
# URL бэкенда панели (как в документации), без завершающего слэша
REMNAWAVE_BASE_URL=https://panel.example.com
# Вариант 1 (рекомендуется): API Token из Remnawave Settings → API Tokens
REMNAWAVE_API_TOKEN=
# Вариант 2: логин по паролю (если токена нет): POST /api/auth/login, токен кешируется в памяти
REMNAWAVE_USERNAME=
REMNAWAVE_PASSWORD=
# Опционально: Internal Squad UUID из панели (через запятую), иначе пользователь создаётся без сквадов
REMNAWAVE_ACTIVE_INTERNAL_SQUADS=
# Internal squads: цепочка задаётся в remnawaveInternalSquads у товара (src/bot/shop/catalog.ts).
REMNAWAVE_STANDARD_INTERNAL_SQUAD_UUID=
# Если UUID не задан — поиск по имени через API (по умолчанию Default-Squad)
# REMNAWAVE_STANDARD_INTERNAL_SQUAD_NAME=Default-Squad
# Для других тарифов — при добавлении remnawaveInternalSquads в каталог, например:
# REMNAWAVE_COMPACT_INTERNAL_SQUAD_UUID=
# REMNAWAVE_PREMIUM_INTERNAL_SQUAD_UUID=
# Общий запасной UUID/имя (alternateUuidEnvVar / alternateNameEnvVar в каталоге)
# REMNAWAVE_BASE_INTERNAL_SQUAD_UUID=
# REMNAWAVE_BASE_INTERNAL_SQUAD_NAME=Default-Squad
# Стратегия лимита трафика для новых пользователей: NO_RESET | DAY | WEEK | MONTH
REMNAWAVE_TRAFFIC_LIMIT_STRATEGY=NO_RESET
# Опционально: только домен вашего сайта (например tvoybuster.shop) — бот создаст u{id}-hex@tvoybuster.shop
# Пусто или удалите строку = поле email не отправляем.
REMNAWAVE_USER_EMAIL_DOMAIN=
# Если панель за Caddy с API-key или нужны заголовки как в доке Remnawave:
# REMNAWAVE_CADDY_API_KEY=
# REMNAWAVE_FORWARDED_FOR=127.0.0.1
# REMNAWAVE_FORWARDED_PROTO=https
# REMNAWAVE_EXTRA_HEADERS={}

# Панель (3x-ui, legacy): куки после POST /login — только если не используете Remnawave
SERVER_URL=https://example.com
SERVER_PORT=12345
SERVER_SUBDOMAIN=secretpath
LOGIN_BODY={"username":"admin","password":"..."}

# ID инбаунда (3x-ui); для режима только Remnawave не используется, в коде подставляется заглушка
PANEL_INBOUND_ID=1

# База URL ссылок подписки — только для офлайн-заглушки без REMNAWAVE_BASE_URL
SUBSCRIPTION_BASE_URL=https://main.co190.com:50000

# Crypto Pay (Crypto Bot) — пополнение баланса через инвойсы
CRYPTOPAY_TOKEN=ваш_ключ_здесь
# По умолчанию USDT. Можно: BTC, TON, ETH, USDT, USDC, BUSD
CRYPTOPAY_ASSET=USDT
# Резервный курс на случай, если getExchangeRates не отдаёт RUB-пару (RUB за 1 ASSET)
CRYPTOPAY_RUB_PER_ASSET=100
